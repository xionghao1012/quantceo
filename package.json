{
  "name": "quantceo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Open-source A-share quantitative trading platform — zero-code strategy backtesting & signal scanning",
  "license": "MIT",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host --port 5173",
    "dev": "tsx watch src/server/index.ts & vite --host --port 5173",
    "build": "tsc && vite build",
    "db:init": "tsx src/server/db/init.ts",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:seed-strategies": "tsx src/server/db/seedStrategies.ts",
    "db:seed-all-stocks": "tsx src/server/db/seed_all_stocks.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "alipay-sdk": "^4.14.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.36.0",
    "echarts": "^5.6.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.13.0",
    "pinia": "^2.2.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-echarts": "^7.0.0",
    "vue-router": "^4.6.4",
    "workerpool": "^10.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.5.15",
    "terser": "^5.48.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
}
